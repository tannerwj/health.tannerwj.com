---
import PageIntro from "../../components/site/PageIntro.astro";
import PracticeDataNotice from "../../components/site/PracticeDataNotice.astro";
import PeptideCalculator from "../../components/calculator/PeptideCalculator.astro";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { calculatorRoute, routeMetadata } from "../../data/site";
---

<BaseLayout
  title={routeMetadata["/peptides/calculator"].title}
  description={routeMetadata["/peptides/calculator"].description}
  canonicalPath={calculatorRoute.href}
>
  <main id="main-content" class="page calculator-page">
    <PageIntro
      eyebrow="Peptides / calculator"
      title="Peptide calculator."
      description="Vial math for BAC water, U-100 units, and named blends. Catalog defaults and saved choices are stored in this browser."
    />

    <div class="wrap calculator-notice">
      <PracticeDataNotice label="Reference note">
        Reference ranges are catalog context, not universal recommendations. The math is deterministic; decisions stay between you and a qualified clinician.
      </PracticeDataNotice>
    </div>

    <PeptideCalculator />
  </main>
</BaseLayout>

<style>
  .calculator-page {
    padding-bottom: 4rem;
  }

  .calculator-notice {
    margin-top: -1rem;
    margin-bottom: 1.5rem;
  }
</style>
