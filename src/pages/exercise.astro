---
import { getCollection } from "astro:content";
import CurrentSplit from "../components/exercise/CurrentSplit.astro";
import ExerciseGroup from "../components/exercise/ExerciseGroup.astro";
import AtAGlance from "../components/site/AtAGlance.astro";
import PageIntro from "../components/site/PageIntro.astro";
import PracticeDataNotice from "../components/site/PracticeDataNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { sortByOrder } from "../lib/content";

const entries = sortByOrder(await getCollection("exercise"));
const currentSplit = entries.find((entry) => entry.data.kind === "split" && entry.data.status === "current");
const supportingEntries = entries.filter((entry) => entry.id !== currentSplit?.id);
const groups = [
  ["Sessions", "Recurring training sessions and conditioning ideas.", "session"],
  ["Principles", "Training principles and ideas for organizing work.", "principle"],
  ["Equipment", "Equipment notes for training.", "equipment"],
  ["Recovery", "Recovery notes related to training.", "recovery"],
  ["Other splits", "Other weekly split ideas and frameworks.", "split"]
] as const;
const hasPracticeEntries = entries.some((entry) => entry.data.practiceOnly);
const glanceItems = groups.slice(0, 4).flatMap(([title, description, kind]) => {
  const count = supportingEntries.filter((entry) => entry.data.kind === kind).length;
  return count ? [{
    label: `${count} ${count === 1 ? "note" : "notes"}`,
    title,
    detail: description,
    href: `#exercise-${title.toLowerCase().replaceAll(" ", "-")}`
  }] : [];
});
---

<BaseLayout
  title="Exercise"
  description="Training notes on principles, sessions, equipment, recovery, and programming ideas."
  canonicalPath="/exercise"
>
  <main id="main-content" class="page">
    <PageIntro eyebrow="03 / Exercise" title="Exercise" description="Training notes, sessions, equipment, recovery, and programming ideas." />
    <AtAGlance items={glanceItems} description="Browse the training library by type. Personal equipment can slot into the same structure." />
    {hasPracticeEntries ? <div class="wrap"><PracticeDataNotice>Practice placeholders below are not Tanner's training plan.</PracticeDataNotice></div> : null}
    <div class="wrap exercise-layout">
      {currentSplit ? <CurrentSplit entry={currentSplit} /> : null}
      {groups.map(([title, description, kind]) => <ExerciseGroup title={title} description={description} entries={supportingEntries.filter((entry) => entry.data.kind === kind)} />)}
    </div>
  </main>
</BaseLayout>

<style>.exercise-layout { padding-block: 0 2.5rem; }</style>
