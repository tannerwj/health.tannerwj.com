---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { blends } from "../data/calculator/blends";
import { compounds } from "../data/calculator/compounds";

const sectionNames = [
  "supplements",
  "sleep",
  "exercise",
  "protocols",
  "peptides",
  "follow"
] as const;

const sectionMeta = {
  supplements: {
    number: "01",
    title: "Supplements",
    description: "The daily and weekly stack, with timing, reason, and product context.",
    href: "/supplements"
  },
  sleep: {
    number: "02",
    title: "Sleep",
    description: "Routine, room, gear, and the small decisions that make nights work.",
    href: "/sleep"
  },
  exercise: {
    number: "03",
    title: "Exercise",
    description: "The current split, training principles, sessions, and recovery pieces.",
    href: "/exercise"
  },
  protocols: {
    number: "04",
    title: "Protocols",
    description: "High-level testing, therapies, nutrition, and recovery practices.",
    href: "/protocols"
  },
  peptides: {
    number: "05",
    title: "Peptides",
    description: "Editorial notes on what I have tried, use, or am still considering.",
    href: "/peptides"
  },
  follow: {
    number: "06",
    title: "Follow",
    description: "People and accounts that keep the thinking interesting and useful.",
    href: "/follow"
  }
} satisfies Record<(typeof sectionNames)[number], {
  number: string;
  title: string;
  description: string;
  href: string;
}>;

const sections = await Promise.all(
  sectionNames.map(async (name) => ({
    name,
    entries: (await getCollection(name)).sort((a, b) => a.data.order - b.data.order)
  }))
);

const featured = sections
  .flatMap((section) =>
    section.entries
      .filter((entry) => entry.data.featured)
      .map((entry) => ({ section: section.name, entry }))
  )
  .sort(
    (a, b) =>
      (a.entry.data.homepageOrder ?? Number.MAX_SAFE_INTEGER) -
      (b.entry.data.homepageOrder ?? Number.MAX_SAFE_INTEGER)
  );

const routeFor = (section: (typeof sectionNames)[number]) => sectionMeta[section].href;
const calculatorCount = compounds.length + blends.length;
const featuredCount = featured.length;
---

<BaseLayout>
  <a class="skip-link" href="#main-content">Skip to main content</a>

  <header class="site-header">
    <div class="header-inner">
      <a class="masthead" href="/" aria-label="health.tannerwj.com home">
        <svg class="masthead-mark" viewBox="0 0 48 48" aria-hidden="true">
          <g class="mark-brackets">
            <path d="M14 10H26" />
            <path d="M14 10V38" />
            <path d="M14 38H26" />
            <path d="M34 10H22" />
            <path d="M34 10V38" />
            <path d="M34 38H22" />
          </g>
          <rect class="mark-register" x="21" y="18" width="6" height="12" rx="1.5" />
        </svg>
        <span class="wordmark">
          health<span>.</span>tannerwj<span>.</span>com
        </span>
      </a>
      <nav class="primary-nav" aria-label="Primary navigation">
        {sectionNames.map((name) => <a class="nav-link" href={routeFor(name)}>{sectionMeta[name].title}</a>)}
        <a class="nav-link nav-link-accent" href="/peptides/calculator">Calculator</a>
      </nav>
    </div>
  </header>

  <main id="main-content" class="page">
    <section class="hero wrap" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">Front page / overview</p>
        <h1 id="page-title">What I do for health, <em>right now</em>.</h1>
        <p class="hero-intro">
          A public, current-state index of Tanner Johnson's health practices: what he takes,
          does, uses, tests, and follows.
        </p>
        <dl class="fact-list hero-facts">
          <div class="fact-item">
            <dt>Sections</dt>
            <dd>06 editorial peers</dd>
          </div>
          <div class="fact-item">
            <dt>Doing now</dt>
            <dd>{featuredCount} selected entries</dd>
          </div>
          <div class="fact-item">
            <dt>Calculator</dt>
            <dd>{calculatorCount} practice records</dd>
          </div>
        </dl>
      </div>
      <nav class="hero-nav" aria-label="Section navigator">
        <p class="hero-nav-title">Section navigator</p>
        <div class="hero-nav-grid">
          {sectionNames.map((name) => {
            const meta = sectionMeta[name];
            return (
              <a class="hero-nav-item" href={meta.href}>
                <span class="hero-nav-number">{meta.number}</span>
                <strong>{meta.title}</strong>
              </a>
            );
          })}
        </div>
      </nav>
    </section>

    <div class="wrap">
      <p class="practice-banner">
        <strong>Practice data</strong>
        <span>The entries below are representative placeholders for implementation and are not Tanner's real stack.</span>
      </p>
    </div>

    <section class="gateway-section" aria-labelledby="calculator-quick-heading">
      <div class="wrap gateway-card">
        <div class="gateway-copy">
          <p class="section-label">Calculator / quick entry</p>
          <h2 id="calculator-quick-heading">Vial math stays in its own lane.</h2>
          <p>
            When you need reconstitution or named-blend math, jump straight to the
            dedicated calculator and keep the rest of the site editorial.
          </p>
        </div>
        <div class="gateway-side">
          <dl class="fact-list gateway-facts">
            <div class="fact-item">
              <dt>Records</dt>
              <dd>{calculatorCount} practice entries</dd>
            </div>
            <div class="fact-item">
              <dt>Modes</dt>
              <dd>Singles and named blends</dd>
            </div>
          </dl>
          <a class="gateway-link" href="/peptides/calculator">
            Open calculator <span aria-hidden="true">↗</span>
          </a>
        </div>
      </div>
    </section>

    <section class="feature-section" aria-labelledby="now-heading">
      <div class="wrap">
        <div class="section-heading">
          <div>
            <p class="section-label">01 / The short list</p>
            <h2 id="now-heading">Doing now</h2>
          </div>
          <p>Selected signals from the collections — the things worth seeing first, not a dump of everything.</p>
        </div>

        <div class="feature-list">
          {featured.map(({ section, entry }, index) => {
            const meta = sectionMeta[section];
            const status = "status" in entry.data ? entry.data.status : undefined;
            return (
              <article class="feature-item">
                <span class="feature-number">{String(index + 1).padStart(2, "0")}</span>
                <span class="feature-type">{meta.title}{status ? ` / ${status}` : ""}</span>
                <div>
                  <h3><a href={meta.href}>{entry.data.name}</a></h3>
                  <p class="feature-summary">{entry.data.summary}</p>
                </div>
                {entry.data.practiceOnly ? <span class="practice-note">Practice entry — replace before launch</span> : null}
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="index-section" aria-labelledby="index-heading">
      <div class="wrap">
        <div class="index-heading">
          <h2 id="index-heading">The index</h2>
          <p>Six peers, one point of view. Pick a section when you want the full working notes behind the headline.</p>
        </div>

        <nav class="index-grid" aria-label="Health field guide sections">
          {sectionNames.map((name) => {
            const meta = sectionMeta[name];
            return (
              <a class="index-item" href={meta.href}>
                <span class="index-number">{meta.number}</span>
                <div>
                  <h3>{meta.title}</h3>
                  <p>{meta.description}</p>
                </div>
              </a>
            );
          })}
        </nav>
      </div>
    </section>

    <section class="calculator-section" aria-labelledby="calculator-heading">
      <div class="wrap calculator-wrap">
        <div>
          <p class="section-label">Calculator zone / {calculatorCount} practice records</p>
          <h2 id="calculator-heading">Peptide calculator.</h2>
          <p>A focused place for vial math, reconstitution, and named blends. Useful when you need it; out of the way when you don't.</p>
          <dl class="fact-list calculator-facts">
            <div class="fact-item">
              <dt>Records</dt>
              <dd>{calculatorCount} practice entries</dd>
            </div>
            <div class="fact-item">
              <dt>Covers</dt>
              <dd>Reconstitution and named blends</dd>
            </div>
            <div class="fact-item">
              <dt>Status</dt>
              <dd>Full calculator remains separate</dd>
            </div>
          </dl>
          <a class="calculator-link" href="/peptides/calculator">
            Open the calculator <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="calculator-mark" aria-hidden="true">
          <svg viewBox="0 0 48 48">
            <g class="mark-brackets">
              <path d="M14 10H26" />
              <path d="M14 10V38" />
              <path d="M14 38H26" />
              <path d="M34 10H22" />
              <path d="M34 10V38" />
              <path d="M34 38H22" />
            </g>
            <rect class="mark-register" x="21" y="18" width="6" height="12" rx="1.5" />
          </svg>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap footer-inner">
      <small>health.tannerwj.com</small>
      <p>This is what I do, not a protocol for you. Some links are affiliate links — they don't change what I recommend.</p>
    </div>
  </footer>
</BaseLayout>
