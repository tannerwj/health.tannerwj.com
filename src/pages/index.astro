---
import PracticeDataNotice from "../components/site/PracticeDataNotice.astro";
import BaseLayout from "../layouts/BaseLayout.astro";
import { blends } from "../data/calculator/blends";
import { compounds } from "../data/calculator/compounds";
import { calculatorRoute, editorialSections, routeMetadata } from "../data/site";
import { getFeaturedEditorialEntries, getOrderedEditorialSections } from "../lib/content";

const sections = await getOrderedEditorialSections();
const featured = getFeaturedEditorialEntries(sections);
const calculatorCount = compounds.length + blends.length;
const featuredCount = featured.length;
const hasPracticeEntries = sections.some(({ entries }) => entries.some((entry) => entry.data.practiceOnly));
---

<BaseLayout title={routeMetadata["/"].title} description={routeMetadata["/"].description} canonicalPath="/">
  <main id="main-content" class="page">
    <section class="hero wrap" aria-labelledby="page-title">
      <div class="hero-copy">
        <p class="eyebrow">Home / six topics</p>
        <h1 id="page-title">What I <em>do</em> for health, right now.</h1>
        <p class="hero-intro">
          Notes on what I take, do, use, test, and follow.
        </p>
        <dl class="hero-facts" aria-label="Homepage facts">
          <div class="fact-item">
            <dt>Sections</dt>
            <dd>06 topics</dd>
          </div>
          <div class="fact-item">
            <dt>Doing now</dt>
            <dd>{featuredCount} selected entries</dd>
          </div>
          <div class="fact-item">
            <dt>Calculator</dt>
            <dd>{calculatorCount} calculator records</dd>
          </div>
        </dl>
      </div>
      <nav class="hero-navigator" aria-label="Health topics">
        <div class="navigator-heading">
          <span class="meta-label">Topics</span>
          <span class="navigator-count">06 + tool</span>
        </div>
        <div class="navigator-links">
          {editorialSections.map((section) => (
            <a href={section.href}><span>{section.number}</span>{section.title}</a>
          ))}
          <a class="navigator-tool" href={calculatorRoute.href}><span aria-hidden="true">↗</span>{calculatorRoute.title}</a>
        </div>
      </nav>
    </section>

    {hasPracticeEntries ? (
      <div class="wrap">
        <PracticeDataNotice>
          Practice placeholders below are not Tanner's real stack.
        </PracticeDataNotice>
      </div>
    ) : null}

    <section class="calculator-gateway wrap" aria-labelledby="gateway-heading">
      <div class="gateway-copy">
        <p class="section-label">Calculator</p>
        <h2 id="gateway-heading">Peptide calculator.</h2>
        <p>
          Vial math for reconstitution and named blends.
        </p>
      </div>
      <div class="gateway-side">
        <dl class="gateway-facts" aria-label="Calculator facts">
          <div class="fact-item">
            <dt>Records</dt>
            <dd>{calculatorCount} curated calculator entries</dd>
          </div>
          <div class="fact-item">
            <dt>Covers</dt>
            <dd>Singles and named blends</dd>
          </div>
        </dl>
        <a class="gateway-link" href={calculatorRoute.href}>Open calculator <span aria-hidden="true">↗</span></a>
      </div>
    </section>

    <section class="feature-section" aria-labelledby="now-heading">
      <div class="wrap">
        <div class="section-heading">
          <div>
            <p class="section-label">01 / The short list</p>
            <h2 id="now-heading">Doing now</h2>
          </div>
          <p>Current entries from across my notes.</p>
        </div>

        <div class="feature-list">
          {featured.map(({ section, entry }, index) => {
            const status = "status" in entry.data ? entry.data.status : undefined;
            return (
              <article class="feature-item">
                <span class="feature-number">{String(index + 1).padStart(2, "0")}</span>
                <span class="feature-type">{section.title}{status ? ` / ${status}` : ""}</span>
                <div>
                  <h3><a href={section.href}>{entry.data.name}</a></h3>
                  <p class="feature-summary">{entry.data.summary}</p>
                </div>
                {entry.data.practiceOnly ? <span class="practice-note">Practice entry — not Tanner's current practice</span> : null}
              </article>
            );
          })}
        </div>
      </div>
    </section>

    <section class="index-section" aria-labelledby="index-heading">
      <div class="wrap">
        <div class="index-heading">
          <h2 id="index-heading">Notes by topic</h2>
          <p>Supplements, sleep, exercise, protocols, peptides, and people I follow.</p>
        </div>

        <nav class="index-grid" aria-label="Health topics">
          {editorialSections.map((section) => {
            return (
              <a class="index-item" href={section.href}>
                <span class="index-number">{section.number}</span>
                <div>
                  <h3>{section.title}</h3>
                  <p>{section.description}</p>
                </div>
              </a>
            );
          })}
        </nav>
      </div>
    </section>

    <section class="calculator-section" aria-labelledby="calculator-heading">
      <div class="wrap calculator-wrap">
        <div>
          <p class="section-label">Calculator / {calculatorCount} records</p>
          <h2 id="calculator-heading">Peptide calculator.</h2>
          <p>Vial math for reconstitution and named blends.</p>
          <a class="calculator-link" href={calculatorRoute.href}>
            Open the calculator <span aria-hidden="true">↗</span>
          </a>
        </div>
        <div class="calculator-mark" aria-hidden="true">÷</div>
      </div>
    </section>
  </main>
</BaseLayout>
