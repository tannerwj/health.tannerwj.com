---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
}

const {
  title = "health.tannerwj.com",
  description =
    "A public field guide to Tanner Johnson's current health practices: what he takes, does, uses, tests, and follows.",
  canonicalPath = "/",
  ogType = "website"
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://health.tannerwj.com");
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const pageTitle = title === "health.tannerwj.com" ? title : `${title} — health.tannerwj.com`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#eef2f4" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content="health.tannerwj.com" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
