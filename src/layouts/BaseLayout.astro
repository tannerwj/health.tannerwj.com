---
import "../styles/global.css";
import SiteFooter from "../components/site/SiteFooter.astro";
import SiteHeader from "../components/site/SiteHeader.astro";
import { SITE_DESCRIPTION, SITE_NAME, SITE_ORIGIN } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  ogTitle?: string;
  ogDescription?: string;
  canonicalPath?: string;
  ogType?: "website" | "article";
}

const {
  title = SITE_NAME,
  description = SITE_DESCRIPTION,
  ogTitle,
  ogDescription,
  canonicalPath = "/",
  ogType = "website"
} = Astro.props;

const siteUrl = Astro.site ?? new URL(SITE_ORIGIN);
const canonicalUrl = new URL(canonicalPath, siteUrl).toString();
const pageTitle = title === SITE_NAME ? title : `${title} — ${SITE_NAME}`;
const socialTitle = ogTitle ?? pageTitle;
const socialDescription = ogDescription ?? description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f1eee8" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:title" content={socialTitle} />
    <meta property="og:description" content={socialDescription} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={socialTitle} />
    <meta name="twitter:description" content={socialDescription} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <SiteHeader />
    <slot />
    <SiteFooter />
  </body>
</html>
