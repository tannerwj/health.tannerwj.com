---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "health.tannerwj.com",
  description = "A personal field guide to what Tanner takes, does, uses, tests, and follows."
} = Astro.props;

const canonicalUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url);
const navigation = [
  { href: "/supplements", label: "Supplements" },
  { href: "/sleep", label: "Sleep" },
  { href: "/exercise", label: "Exercise" },
  { href: "/protocols", label: "Protocols" },
  { href: "/peptides", label: "Peptides" },
  { href: "/follow", label: "Follow" }
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:site_name" content="health.tannerwj.com" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta name="twitter:card" content="summary" />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="site-header">
      <div class="site-header__inner">
        <a class="wordmark" href="/" aria-label="health.tannerwj.com home">health.tannerwj.com</a>
        <nav class="site-nav" aria-label="Primary navigation">
          {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        </nav>
      </div>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="site-footer">
      <p>This is what I do, not a protocol for you. Some links are affiliate links -- they don't change what I recommend.</p>
    </footer>
  </body>
</html>
