---
import { calculatorRoute, primaryNav, siteTitle } from "../lib/site";

interface Props {
  currentPath?: string;
}

const { currentPath = "/" } = Astro.props;

function isCurrent(href: string): boolean {
  if (href === "/") {
    return currentPath === "/";
  }

  return currentPath === href || currentPath.startsWith(`${href}/`);
}

const isCalculatorCurrent = currentPath === calculatorRoute.href;
---

<header class="site-header">
  <div class="site-shell site-header__inner">
    <a class="site-brand" href="/">
      <span class="site-mark" aria-hidden="true"></span>
      <span>{siteTitle}</span>
    </a>

    <nav aria-label="Primary" class="primary-nav">
      <ul>
        {
          primaryNav.map((item) => (
            <li>
              <a
                class="nav-link"
                href={item.href}
                aria-current={isCurrent(item.href) ? "page" : undefined}
              >
                {item.label}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <a
      class="utility-link"
      href={calculatorRoute.href}
      aria-current={isCalculatorCurrent ? "page" : undefined}
    >
      {calculatorRoute.label}
    </a>
  </div>
</header>
