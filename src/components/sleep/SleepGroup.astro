---
import type { CollectionEntry } from "astro:content";
import SleepEntry from "./SleepEntry.astro";

interface Props {
  title: string;
  description: string;
  entries: CollectionEntry<"sleep">[];
}

const { title, description, entries } = Astro.props;
const id = `sleep-${title.toLowerCase()}`;
---

{entries.length ? (
  <section class="sleep-group" aria-labelledby={id}>
    <header>
      <p class="section-label">Night / {title}</p>
      <h2 id={id}>{title}</h2>
      <p>{description}</p>
    </header>
    <div class="entries">
      {entries.map((entry) => <SleepEntry entry={entry} />)}
    </div>
  </section>
) : null}

<style>
  .sleep-group { padding-block: 2.25rem; border-top: 1px solid var(--line-strong); }
  header { display: grid; gap: .65rem; max-width: 43rem; margin-bottom: 1.25rem; }
  h2 { margin: 0; font-family: var(--serif); font-size: clamp(2rem, 7vw, 4rem); font-weight: 400; line-height: .95; }
  header > p:last-child { margin: 0; color: var(--muted); line-height: 1.45; }
</style>
