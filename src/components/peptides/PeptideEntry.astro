---
import { render, type CollectionEntry } from "astro:content";
import { blends } from "../../data/calculator/blends";
import { compounds } from "../../data/calculator/compounds";
import { calculatorHrefForCatalogEntry } from "../../lib/calculator/catalog-query";

interface Props {
  entry: CollectionEntry<"peptides">;
  calculatorAvailable: boolean;
}

const { entry, calculatorAvailable } = Astro.props;
const { Content } = await render(entry);
const evidenceLabels = {
  "established-human-use": "Established human use",
  "human-trial": "Human trials",
  "limited-human": "Limited human data",
  preclinical: "Preclinical",
  "component-extrapolation": "Component extrapolation"
} as const;
const statusLabels = { current: "Current", considering: "Considering", "previously-tried": "Previously tried" } as const;
const composition = entry.data.components?.join(" · ") ?? entry.data.aliases?.join(" · ") ?? "Single compound";
const calculatorHref = calculatorAvailable
  ? calculatorHrefForCatalogEntry(
      entry.data.form === "blend" ? "blend" : "single",
      entry.data.calculatorId,
      {
        compoundIds: compounds.map((compound) => compound.id),
        blendIds: blends.map((blend) => blend.id)
      }
    )
  : null;
---

<article class="peptide-entry" id={entry.data.slug}>
  <header>
    <div class="badges">
      <span>{entry.data.form}</span>
      <span>{evidenceLabels[entry.data.evidenceMaturity]}</span>
      <span>{entry.data.entryType === "source-note" ? "Source note" : statusLabels[entry.data.status!]}</span>
    </div>
    <p class="entry-number">{String(entry.data.order).padStart(2, "0")}</p>
    <h3>{entry.data.name}</h3>
    <p class="summary">{entry.data.atAGlance}</p>
  </header>

  <dl class="quick-facts">
    <div><dt>{entry.data.form === "blend" ? "Composition" : "Identity"}</dt><dd>{composition}</dd></div>
    <div><dt>Common context</dt><dd>{entry.data.commonContext}</dd></div>
  </dl>

  <details class="reference-details">
    <summary>Mechanism, evidence, and sources</summary>
    <div class="details-body">
      {entry.data.mechanism ? <p><strong>Mechanism:</strong> {entry.data.mechanism}</p> : null}
      <p><strong>Evidence:</strong> {entry.data.evidenceNote}</p>
      <div class="entry-body"><Content /></div>
      <ul class="sources">
        {entry.data.sources?.map((source) => (
          <li>
            {source.url ? <a href={source.url} target="_blank" rel="noreferrer">{source.author ?? source.type}</a> : <span>{source.author ?? source.type}</span>}
            {source.note ? ` — ${source.note}` : null}
          </li>
        ))}
      </ul>
    </div>
  </details>

  {calculatorHref ? <a class="calculator-link" href={calculatorHref}>Open in calculator <span aria-hidden="true">↗</span></a> : null}
</article>

<style>
  .peptide-entry { position: relative; display: grid; gap: 1rem; margin-top: .8rem; border: 1px solid var(--line-strong); border-left: 4px solid var(--sage); padding: 1rem; background: rgba(248, 246, 238, .54); scroll-margin-top: 1rem; }
  header { min-width: 0; }
  .badges { display: flex; flex-wrap: wrap; gap: .35rem; margin-bottom: .75rem; }
  .badges span { border: 1px solid var(--line-strong); padding: .25rem .4rem; color: var(--sage-deep); font-size: .56rem; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }
  .entry-number { margin: 0; color: var(--clay-deep); font-size: .64rem; font-weight: 900; letter-spacing: .12em; }
  h3 { margin: .35rem 0 0; font-family: var(--serif); font-size: clamp(1.65rem, 6vw, 2.55rem); font-weight: 400; letter-spacing: 0; line-height: .95; }
  .summary { max-width: 36rem; margin: .65rem 0 0; color: var(--muted); font-size: .9rem; line-height: 1.43; }
  .quick-facts { display: grid; gap: .65rem; margin: 0; }
  .quick-facts div { border-top: 1px solid var(--line); padding-top: .5rem; }
  dt { color: var(--clay-deep); font-size: .57rem; font-weight: 900; letter-spacing: .11em; text-transform: uppercase; }
  dd { margin: .25rem 0 0; color: var(--ink); font-size: .78rem; font-weight: 750; line-height: 1.4; }
  .reference-details { border-top: 1px solid var(--line); color: var(--muted); font-size: .8rem; line-height: 1.5; }
  summary { cursor: pointer; min-height: 44px; padding-top: .75rem; color: var(--ink); font-weight: 900; }
  .details-body { padding-bottom: .25rem; }
  .details-body > p, .entry-body :global(p) { margin: .75rem 0 0; }
  .sources { margin: .85rem 0 0; padding-left: 1.05rem; }
  .sources li + li { margin-top: .35rem; }
  .sources a { color: var(--sage-deep); font-weight: 850; }
  .calculator-link { display: inline-flex; align-items: center; justify-content: space-between; gap: .8rem; width: fit-content; min-height: 44px; border-bottom: 1px solid var(--sage-deep); color: var(--sage-deep); font-size: .68rem; font-weight: 900; letter-spacing: .05em; text-decoration: none; text-transform: uppercase; }
  .calculator-link:hover, .calculator-link:focus-visible { color: var(--clay-deep); border-bottom-color: var(--clay-deep); }
  @media (min-width: 48rem) {
    .peptide-entry { grid-template-columns: minmax(0, 1.05fr) minmax(15rem, .75fr); column-gap: 2.5rem; padding: 1.25rem 1.35rem; }
    header, .reference-details { grid-column: 1; }
    .quick-facts { grid-column: 2; grid-row: 1 / span 2; align-content: start; }
    .calculator-link { grid-column: 2; align-self: end; }
  }
</style>
