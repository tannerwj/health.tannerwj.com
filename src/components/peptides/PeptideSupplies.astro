---
import type { CollectionEntry } from "astro:content";
import { amazonLinkLabel, getAffiliateEntries } from "../../lib/affiliates";
import AmazonDisclosure from "../site/AmazonDisclosure.astro";

interface Props {
  entries: CollectionEntry<"supplies">[];
}

const { entries } = Astro.props;
---

<section class="supplies-section" aria-labelledby="supplies-heading">
  <div class="wrap">
    <header class="supplies-heading">
      <p class="section-label">Products / Supplies</p>
      <h2 id="supplies-heading">Supply links.</h2>
      <p>These links do not describe my current setup.</p>
      <AmazonDisclosure />
    </header>
    <div class="supply-grid">
      {entries.map((entry) => {
        const affiliateEntries = getAffiliateEntries(entry.data);
        return (
          <article class="supply-entry" id={entry.data.slug}>
            <p class="entry-label">Supply link</p>
            <h3>{entry.data.name}</h3>
            <p>{entry.data.summary}</p>
            {affiliateEntries.map((affiliate) => (
              <a href={affiliate.url} rel="sponsored noreferrer">
                {amazonLinkLabel(affiliate, entry.data.name)} <span aria-hidden="true">↗</span>
              </a>
            ))}
          </article>
        );
      })}
    </div>
  </div>
</section>

<style>
  .supplies-section { border-bottom: 1px solid var(--line-strong); padding-block: 2.5rem; background: rgba(227, 229, 220, .32); }
  .supplies-heading { max-width: 44rem; }
  .supplies-heading h2 { max-width: 14ch; margin: .5rem 0 0; font-family: var(--serif); font-size: clamp(2rem, 7vw, 3.6rem); font-weight: 400; line-height: .92; }
  .supplies-heading > p { margin: .85rem 0 0; color: var(--muted); font-size: .9rem; line-height: 1.5; }
  .supply-grid { display: grid; gap: .8rem; margin-top: 1.5rem; }
  .supply-entry { border: 1px solid var(--line-strong); border-top: 3px solid var(--sage); padding: 1rem; background: rgba(248, 246, 238, .62); }
  .entry-label { margin: 0; color: var(--clay-deep); font-size: .6rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
  .supply-entry h3 { margin: .35rem 0 0; font-family: var(--serif); font-size: clamp(1.5rem, 5vw, 2.15rem); font-weight: 400; line-height: 1; }
  .supply-entry > p:not(.entry-label) { margin: .7rem 0 0; color: var(--muted); font-size: .86rem; line-height: 1.45; }
  .supply-entry a { display: inline-flex; align-items: center; min-height: 44px; margin-top: .65rem; border-bottom: 1px solid var(--sage-deep); color: var(--sage-deep); font-size: .78rem; font-weight: 900; text-decoration: none; }
  @media (min-width: 48rem) {
    .supplies-section { padding-block: 3rem; }
    .supply-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .supply-entry { padding: 1.25rem 1.35rem; }
  }
</style>
