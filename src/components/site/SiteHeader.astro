---
import { calculatorRoute, editorialSections } from "../../data/site";
---

<header class="site-header">
  <div class="header-inner">
    <a class="brand-lockup" href="/" aria-label="Tanner's Field Notes home">
      <svg class="field-mark" viewBox="0 0 44 44" aria-hidden="true">
        <circle cx="22" cy="22" r="19.25" fill="none" stroke="currentColor" stroke-width="1" />
        <g fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.65">
          <path d="M22 6.5a15.5 15.5 0 0 1 7.75 2.076" />
          <path d="M22 6.5a15.5 15.5 0 0 1 7.75 2.076" transform="rotate(60 22 22)" />
          <path d="M22 6.5a15.5 15.5 0 0 1 7.75 2.076" transform="rotate(120 22 22)" />
          <path d="M22 6.5a15.5 15.5 0 0 1 7.75 2.076" transform="rotate(180 22 22)" />
          <path d="M22 6.5a15.5 15.5 0 0 1 7.75 2.076" transform="rotate(240 22 22)" />
          <path d="M22 6.5a15.5 15.5 0 0 1 7.75 2.076" transform="rotate(300 22 22)" />
        </g>
        <path d="M16.5 17h11M22 17v12" fill="none" stroke="currentColor" stroke-linecap="round" stroke-width="1.25" />
      </svg>
      <span class="wordmark">
        <strong>Field Notes</strong>
        <small>Tanner Johnson · Health</small>
      </span>
    </a>
    <nav class="primary-nav" aria-label="Primary navigation">
      {editorialSections.map((section) => <a href={section.href}>{section.title}</a>)}
      <a href={calculatorRoute.href}>{calculatorRoute.title}</a>
    </nav>
  </div>
</header>
