---
interface Props {
  href: string;
}

const { href } = Astro.props;
---

<aside class="share-strip" aria-label="Share this page">
  <div class="wrap share-strip-inner">
    <p>Worth keeping?</p>
    <a href={href} target="_blank" rel="noopener noreferrer">
      Share on X <span aria-hidden="true">↗</span><span class="sr-only"> (opens in a new tab)</span>
    </a>
  </div>
</aside>
