---
import { render, type CollectionEntry } from "astro:content";
import PracticeDataNotice from "../site/PracticeDataNotice.astro";
import affiliates from "../../data/affiliates.json";

interface Props {
  title: string;
  description: string;
  entries: CollectionEntry<"exercise">[];
}

const { title, description, entries } = Astro.props;
const affiliateRegistry = affiliates as Record<string, { vendor: string; url: string }>;
const id = `exercise-${title.toLowerCase().replaceAll(" ", "-")}`;
---

{entries.length ? (
  <section class="exercise-group" aria-labelledby={id}>
    <header>
      <p class="section-label">Training / {title}</p>
      <h2 id={id}>{title}</h2>
      <p>{description}</p>
    </header>
    <ol>
      {entries.map(async (entry) => {
        const { Content } = await render(entry);
        const hasNotes = Boolean(entry.body?.trim());
        const affiliate = entry.data.affiliate ? affiliateRegistry[entry.data.affiliate] : undefined;
        return (
          <li>
            <article>
              <div class="entry-heading">
                <div>
                  <div class="entry-meta">
                    <p class="entry-kind">{entry.data.kind}</p>
                    {entry.data.sources?.length && !entry.data.status ? <p class="source-note">Source note</p> : null}
                  </div>
                  <h3>{entry.data.name}</h3>
                </div>
                {entry.data.status ? <span class="status">{entry.data.status.replaceAll("-", " ")}</span> : null}
              </div>
              <p class="summary">{entry.data.summary}</p>
              {entry.data.schedule || entry.data.frequency || entry.data.duration || entry.data.spec ? (
                <dl>
                  {entry.data.schedule ? <div><dt>Schedule</dt><dd>{entry.data.schedule}</dd></div> : null}
                  {entry.data.frequency ? <div><dt>Cadence</dt><dd>{entry.data.frequency}</dd></div> : null}
                  {entry.data.duration ? <div><dt>Duration</dt><dd>{entry.data.duration}</dd></div> : null}
                  {entry.data.spec ? <div><dt>Details</dt><dd>{entry.data.spec}</dd></div> : null}
                </dl>
              ) : null}
              {affiliate ? <a class="product-link" href={affiliate.url} rel="noreferrer">Product context: {affiliate.vendor} <span aria-hidden="true">↗</span></a> : null}
              {entry.data.practiceOnly ? <PracticeDataNotice label="Practice entry">{entry.data.practiceNote ?? "Practice data only — not Tanner's training plan."}</PracticeDataNotice> : null}
              {hasNotes ? <details><summary>Notes and context</summary><div class="markdown"><Content /></div></details> : null}
            </article>
          </li>
        );
      })}
    </ol>
  </section>
) : null}

<style>
  .exercise-group { border-top: 1px solid var(--line-strong); padding-block: 2.4rem; }
  header { display: grid; gap: .65rem; max-width: 42rem; margin-bottom: 1.25rem; }
  h2, h3 { margin: 0; font-family: var(--serif); font-weight: 400; }
  h2 { font-size: clamp(2.1rem, 8vw, 4.4rem); line-height: .93; }
  header > p:last-child { margin: 0; color: var(--muted); line-height: 1.45; }
  ol { margin: 0; padding: 0; list-style: none; }
  article { border-top: 1px solid var(--line); padding-block: 1.25rem 1.45rem; }
  .entry-heading { display: flex; justify-content: space-between; align-items: start; gap: 1rem; }
  .entry-meta { display: flex; flex-wrap: wrap; gap: .4rem .8rem; }
  .entry-kind, .source-note, .status { margin: 0; color: var(--clay-deep); font-size: .64rem; font-weight: 900; letter-spacing: .13em; text-transform: uppercase; }
  .status { color: var(--muted); text-align: right; }
  h3 { margin-top: .3rem; font-size: clamp(1.55rem, 6vw, 2.5rem); line-height: .98; }
  .summary { max-width: 46rem; margin: .8rem 0 0; line-height: 1.5; }
  dl { display: flex; flex-wrap: wrap; gap: .7rem 1.4rem; margin: 1rem 0 0; }
  dl div { min-width: 7rem; } dt { color: var(--muted); font-size: .62rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; } dd { margin: .25rem 0 0; font-size: .88rem; line-height: 1.4; }
  .product-link { display: inline-flex; align-items: center; min-height: 44px; margin-top: .5rem; color: var(--sage-deep); font-size: .87rem; font-weight: 800; text-underline-offset: .2em; }
  details { margin-top: .6rem; border-top: 1px solid var(--line); } summary { display: flex; align-items: center; min-height: 44px; cursor: pointer; color: var(--sage-deep); font-size: .86rem; font-weight: 800; } .markdown { max-width: 44rem; padding-bottom: .3rem; line-height: 1.6; }
</style>
