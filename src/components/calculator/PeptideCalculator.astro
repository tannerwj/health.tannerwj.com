---
import { syringeCapacityOptions, syringeCapacityUnits } from "../../data/calculator/engine";
import { blends } from "../../data/calculator/blends";
import { compounds } from "../../data/calculator/compounds";
import {
  buildWaterPresetOptions,
  formatQuantity,
  getBlendDefaults,
  getCompoundDisplayName,
  getSingleCompoundDefaults
} from "../../lib/calculator/catalog-ui";

const compoundsById = Object.fromEntries(compounds.map((compound) => [compound.id, compound]));
const initialCompound = compounds[0];
const initialBlend = blends[0];
const initialSingle = getSingleCompoundDefaults(initialCompound);
const initialBlendDefaults = getBlendDefaults(initialBlend, compoundsById);
const singleWaterPresets = buildWaterPresetOptions(initialCompound.commonWaterMl);
const blendWaterPresets = buildWaterPresetOptions(initialBlend.commonWaterMl);
---

<section class="calculator-shell wrap" data-calculator-root aria-label="Peptide calculator">
  <div class="calculator-topline">
    <fieldset class="mode-switch" aria-label="Calculator mode">
      <legend>Calculator mode</legend>
      <label>
        <input type="radio" name="calculator-mode" value="single" data-mode-input checked />
        <span>Single compound</span>
      </label>
      <label>
        <input type="radio" name="calculator-mode" value="blend" data-mode-input />
        <span>Blend vial</span>
      </label>
    </fieldset>

    <div class="storage-panel" aria-live="polite">
      <p data-save-status>Using catalog defaults. Changes save in this browser.</p>
      <button type="button" data-reset-defaults>Reset to catalog defaults</button>
    </div>
  </div>

  <noscript>
    <p class="noscript-note">
      This calculator uses JavaScript for calculations and saved choices.
    </p>
  </noscript>

  <form class="calculator-form" data-calculator-form>
    <div class="input-column">
      <section class="calculator-panel" data-mode-section="single" aria-labelledby="single-heading">
        <div class="panel-heading">
          <p class="section-label">Single / catalog</p>
          <h2 id="single-heading">Compound vial</h2>
        </div>

        <div class="field-stack">
          <div class="control-block catalog-finder">
            <label for="compound-search">Search compounds</label>
            <input
              id="compound-search"
              type="search"
              autocomplete="off"
              data-compound-search
              role="combobox"
              aria-autocomplete="list"
              aria-controls="compound-search-results"
              aria-expanded="false"
              placeholder="Type a name or alias"
            />
            <div class="finder-status">
              <span data-compound-search-count aria-live="polite"></span>
              <span>↑↓ to move · Enter to choose</span>
            </div>
            <ul id="compound-search-results" class="finder-results" role="listbox" data-compound-search-results hidden></ul>
            <p class="finder-empty" data-compound-search-empty hidden>No compounds match that search.</p>
          </div>

          <div class="select-row">
            <div class="control-block">
              <label for="compound-select">Selected compound</label>
              <select id="compound-select" data-compound-select>
                {compounds.map((compound) => (
                  <option value={compound.id} selected={compound.id === initialCompound.id}>
                    {compound.name}
                  </option>
                ))}
              </select>
            </div>
            <button type="button" class="favorite-button" data-single-favorite aria-pressed="false">
              Favorite
            </button>
          </div>

          <p class="catalog-note" data-compound-summary>{initialCompound.description}</p>
        </div>

        <fieldset class="control-group">
          <legend>Vial amount</legend>
          <div class="chip-grid" data-single-vial-presets aria-label="Common vial amounts"></div>
          <div class="inline-fields">
            <label>
              <span>Other amount</span>
              <input
                type="number"
                min="0"
                step="any"
                inputmode="decimal"
                value={initialSingle.vialQuantity.value}
                data-single-vial-custom-value
              />
            </label>
            <label>
              <span>Unit</span>
              <select data-single-vial-custom-unit>
                <option value="mg" selected={initialSingle.vialQuantity.unit === "mg"}>mg</option>
                <option value="mcg" selected={initialSingle.vialQuantity.unit === "mcg"}>mcg</option>
              </select>
            </label>
          </div>
        </fieldset>

        <fieldset class="control-group">
          <legend>BAC water</legend>
          <div class="chip-grid" data-single-water-presets aria-label="Common BAC-water volumes">
            {singleWaterPresets.map((option) => (
              <button type="button" data-water-value={option.value}>{option.label}</button>
            ))}
          </div>
          <label class="single-field">
            <span>BAC water mL</span>
            <input
              type="number"
              min="0"
              step="any"
              inputmode="decimal"
              value={initialSingle.waterVolumeMl}
              data-single-water
            />
          </label>
        </fieldset>

        <fieldset class="control-group">
          <legend>Desired dose</legend>
          <div class="chip-grid" data-single-dose-presets aria-label="Dose presets"></div>
          <div class="inline-fields">
            <label>
              <span>Dose amount</span>
              <input
                type="number"
                min="0"
                step="any"
                inputmode="decimal"
                value={initialSingle.desiredDose.value}
                data-single-dose-value
              />
            </label>
            <label>
              <span>Unit</span>
              <select data-single-dose-unit>
                <option value="mcg" selected={initialSingle.desiredDose.unit === "mcg"}>mcg</option>
                <option value="mg" selected={initialSingle.desiredDose.unit === "mg"}>mg</option>
              </select>
            </label>
          </div>
        </fieldset>

        <fieldset class="control-group">
          <legend>U-100 syringe capacity</legend>
          <div class="chip-grid">
            {syringeCapacityOptions.map((capacity) => (
              <label class="radio-chip">
                <input
                  type="radio"
                  name="single-syringe"
                  value={capacity}
                  data-single-syringe
                  checked={capacity === initialSingle.syringeCapacityMl}
                />
                <span>{capacity.toFixed(1)} mL / {syringeCapacityUnits[capacity]} units</span>
              </label>
            ))}
          </div>
        </fieldset>
      </section>

      <section class="calculator-panel" data-mode-section="blend" aria-labelledby="blend-heading" hidden>
        <div class="panel-heading">
          <p class="section-label">Blend / named blends</p>
          <h2 id="blend-heading">Shared draw</h2>
        </div>

        <div class="field-stack">
          <div class="control-block catalog-finder">
            <label for="blend-search">Search blends</label>
            <input
              id="blend-search"
              type="search"
              autocomplete="off"
              data-blend-search
              role="combobox"
              aria-autocomplete="list"
              aria-controls="blend-search-results"
              aria-expanded="false"
              placeholder="Type a blend or variant"
            />
            <div class="finder-status">
              <span data-blend-search-count aria-live="polite"></span>
              <span>↑↓ to move · Enter to choose</span>
            </div>
            <ul id="blend-search-results" class="finder-results" role="listbox" data-blend-search-results hidden></ul>
            <p class="finder-empty" data-blend-search-empty hidden>No blends match that search.</p>
          </div>

          <div class="select-row">
            <div class="control-block">
              <label for="blend-select">Selected blend</label>
              <select id="blend-select" data-blend-select>
                {blends.map((blend) => (
                  <option value={blend.id} selected={blend.id === initialBlend.id}>
                    {blend.name} - {blend.variant}
                  </option>
                ))}
              </select>
            </div>
            <button type="button" class="favorite-button" data-blend-favorite aria-pressed="false">
              Favorite
            </button>
          </div>
        </div>

        <div class="component-list" aria-label="Blend vial components" data-blend-components>
          {initialBlend.components.map((component) => (
            <div>
              <span>{getCompoundDisplayName(component.compoundId, compoundsById)}</span>
              <strong>{formatQuantity(component.amount)}</strong>
            </div>
          ))}
        </div>

        <fieldset class="control-group">
          <legend>BAC water</legend>
          <div class="chip-grid" data-blend-water-presets aria-label="Common BAC-water volumes">
            {blendWaterPresets.map((option) => (
              <button type="button" data-water-value={option.value}>{option.label}</button>
            ))}
          </div>
          <label class="single-field">
            <span>BAC water mL</span>
            <input
              type="number"
              min="0"
              step="any"
              inputmode="decimal"
              value={initialBlendDefaults.waterVolumeMl}
              data-blend-water
            />
          </label>
        </fieldset>

        <fieldset class="control-group">
          <legend>Draw mode</legend>
          <div class="chip-grid">
            <label class="radio-chip">
              <input
                type="radio"
                name="blend-draw-mode"
                value="anchor"
                data-blend-draw-mode
                checked={initialBlendDefaults.mode.kind === "anchor"}
              />
              <span>Anchor component</span>
            </label>
            <label class="radio-chip">
              <input
                type="radio"
                name="blend-draw-mode"
                value="direct"
                data-blend-draw-mode
                checked={initialBlendDefaults.mode.kind === "direct"}
              />
              <span>Direct draw</span>
            </label>
          </div>
        </fieldset>

        <div class="draw-mode-panel" data-blend-anchor-panel>
          <div class="control-block">
            <label for="blend-anchor">Anchor component</label>
            <select id="blend-anchor" data-blend-anchor-select>
              {initialBlend.components.map((component) => (
                <option
                  value={component.compoundId}
                  selected={
                    initialBlendDefaults.mode.kind === "anchor" &&
                    component.compoundId === initialBlendDefaults.mode.anchorCompoundId
                  }
                >
                  {getCompoundDisplayName(component.compoundId, compoundsById)}
                </option>
              ))}
            </select>
          </div>
          <div class="chip-grid" data-blend-dose-presets aria-label="Blend anchor dose presets"></div>
          <div class="inline-fields">
            <label>
              <span>Anchor target</span>
              <input
                type="number"
                min="0"
                step="any"
                inputmode="decimal"
                value={initialBlendDefaults.mode.kind === "anchor" ? initialBlendDefaults.mode.target.value : 250}
                data-blend-anchor-dose-value
              />
            </label>
            <label>
              <span>Unit</span>
              <select data-blend-anchor-dose-unit>
                <option
                  value="mcg"
                  selected={initialBlendDefaults.mode.kind !== "anchor" || initialBlendDefaults.mode.target.unit === "mcg"}
                >
                  mcg
                </option>
                <option
                  value="mg"
                  selected={initialBlendDefaults.mode.kind === "anchor" && initialBlendDefaults.mode.target.unit === "mg"}
                >
                  mg
                </option>
              </select>
            </label>
          </div>
        </div>

        <div class="draw-mode-panel" data-blend-direct-panel hidden>
          <div class="inline-fields">
            <label>
              <span>Draw amount</span>
              <input type="number" min="0" step="any" inputmode="decimal" value="10" data-blend-direct-value />
            </label>
            <label>
              <span>Unit</span>
              <select data-blend-direct-unit>
                <option value="units">U-100 units</option>
                <option value="mL">mL</option>
              </select>
            </label>
          </div>
        </div>

        <fieldset class="control-group">
          <legend>U-100 syringe capacity</legend>
          <div class="chip-grid">
            {syringeCapacityOptions.map((capacity) => (
              <label class="radio-chip">
                <input
                  type="radio"
                  name="blend-syringe"
                  value={capacity}
                  data-blend-syringe
                  checked={capacity === initialBlendDefaults.syringeCapacityMl}
                />
                <span>{capacity.toFixed(1)} mL / {syringeCapacityUnits[capacity]} units</span>
              </label>
            ))}
          </div>
        </fieldset>
      </section>
    </div>

    <section class="results-panel" aria-labelledby="result-heading">
      <div class="result-heading">
        <p class="section-label">Result / calculated draw</p>
        <h2 id="result-heading">Calculated draw.</h2>
      </div>

      <div class="result-state" data-result-state aria-live="polite">
        Enter positive quantities to calculate the draw.
      </div>

      <div class="syringe-visual" aria-label="Syringe fill preview">
        <div class="syringe-scale">
          <div class="syringe-fill" data-syringe-fill></div>
        </div>
        <div class="syringe-ticks" data-syringe-ticks></div>
      </div>

      <div class="result-grid" data-single-results></div>
      <div class="result-grid" data-blend-results hidden></div>

      <div class="alert-list" data-alerts aria-live="polite"></div>
      <div class="error-list" data-errors role="alert" aria-live="assertive" hidden></div>

      <p class="result-footnote">
        U-100 means 100 units per mL. The calculator echoes doses in mg and mcg so unit changes stay visible.
      </p>
    </section>
  </form>
</section>

<script>
  import "../../scripts/calculator";
</script>

<style>
  .calculator-shell {
    display: grid;
    gap: 1rem;
  }

  .calculator-topline {
    display: grid;
    gap: 1rem;
    border-block: 1px solid var(--line-strong);
    padding-block: 1rem;
  }

  .mode-switch,
  .control-group {
    min-inline-size: 0;
    margin: 0;
    border: 0;
    padding: 0;
  }

  .mode-switch legend,
  .control-group legend {
    margin-bottom: 0.55rem;
    color: var(--clay-deep);
    font-size: 0.66rem;
    font-weight: 900;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .mode-switch {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.5rem;
  }

  .mode-switch legend {
    grid-column: 1 / -1;
  }

  .mode-switch label,
  .radio-chip {
    position: relative;
    display: flex;
    align-items: center;
    min-height: 44px;
    border: 1px solid var(--line-strong);
    background: rgba(241, 238, 232, 0.64);
    cursor: pointer;
  }

  .mode-switch input,
  .radio-chip input {
    position: absolute;
    inline-size: 1px;
    block-size: 1px;
    opacity: 0;
  }

  .mode-switch span,
  .radio-chip span {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    min-height: 44px;
    padding: 0.7rem 0.85rem;
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    text-align: center;
    text-transform: uppercase;
  }

  .mode-switch input:checked + span,
  .radio-chip input:checked + span {
    background: var(--ink);
    color: var(--paper);
  }

  .mode-switch input:focus-visible + span,
  .radio-chip input:focus-visible + span {
    outline: 3px solid var(--clay);
    outline-offset: 3px;
  }

  .storage-panel {
    display: grid;
    gap: 0.65rem;
    align-content: start;
  }

  .storage-panel p,
  .catalog-note,
  .result-footnote,
  .noscript-note {
    margin: 0;
    color: var(--muted);
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .storage-panel button,
  .favorite-button,
  .chip-grid button {
    min-height: 44px;
    border: 1px solid var(--line-strong);
    border-radius: 0;
    background: transparent;
    color: var(--ink);
    cursor: pointer;
    font: inherit;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .storage-panel button:hover,
  .favorite-button:hover,
  .chip-grid button:hover,
  .chip-grid button[aria-pressed="true"],
  .favorite-button[aria-pressed="true"] {
    border-color: var(--sage-deep);
    background: var(--sage-deep);
    color: var(--paper);
  }

  .calculator-form {
    display: grid;
    gap: 1rem;
  }

  .input-column,
  .calculator-panel,
  .field-stack {
    display: grid;
    gap: 1rem;
    min-width: 0;
  }

  .calculator-panel,
  .results-panel {
    border: 1px solid var(--ink);
    background: rgba(241, 238, 232, 0.74);
    padding: 1rem;
  }

  .calculator-panel[hidden],
  .draw-mode-panel[hidden],
  .result-grid[hidden] {
    display: none;
  }

  .panel-heading,
  .result-heading {
    display: grid;
    gap: 0.55rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1rem;
  }

  .panel-heading h2,
  .result-heading h2 {
    margin: 0;
    font-family: var(--serif);
    font-size: 2.15rem;
    font-weight: 400;
    letter-spacing: 0;
    line-height: 0.9;
  }

  .control-block,
  .single-field,
  .inline-fields label {
    display: grid;
    gap: 0.35rem;
  }

  .catalog-finder {
    position: relative;
  }

  .finder-status {
    display: flex;
    flex-wrap: wrap;
    justify-content: space-between;
    gap: 0.35rem 0.8rem;
    color: var(--muted);
    font-size: 0.65rem;
    font-weight: 750;
    line-height: 1.35;
  }

  .finder-results {
    display: grid;
    max-height: 19rem;
    margin: 0;
    border: 1px solid var(--line-strong);
    padding: 0;
    overflow-y: auto;
    background: var(--paper);
    list-style: none;
  }

  .finder-results[hidden] {
    display: none;
  }

  .finder-results :global(li) {
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 0.2rem 0.75rem;
    min-height: 48px;
    border-bottom: 1px solid var(--line);
    padding: 0.65rem 0.75rem;
    cursor: pointer;
  }

  .finder-results :global(li:last-child) {
    border-bottom: 0;
  }

  .finder-results :global(li:hover),
  .finder-results :global(li[aria-selected="true"]) {
    background: var(--sage-deep);
    color: var(--paper);
  }

  .finder-results :global(strong) {
    min-width: 0;
    font-size: 0.82rem;
    letter-spacing: 0;
    line-height: 1.25;
  }

  .finder-results :global(small) {
    grid-column: 1;
    min-width: 0;
    color: var(--muted);
    font-size: 0.69rem;
    line-height: 1.3;
  }

  .finder-results :global(li:hover small),
  .finder-results :global(li[aria-selected="true"] small) {
    color: rgba(248, 246, 238, 0.78);
  }

  .finder-results :global(.favorite-marker) {
    grid-column: 2;
    grid-row: 1 / span 2;
    align-self: center;
    color: var(--clay-deep);
    font-size: 0.65rem;
    font-weight: 900;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }

  .finder-results :global(li:hover .favorite-marker),
  .finder-results :global(li[aria-selected="true"] .favorite-marker) {
    color: var(--paper);
  }

  .finder-results :global(mark) {
    background: rgba(181, 144, 111, 0.35);
    color: inherit;
  }

  .finder-empty {
    margin: 0;
    border-left: 3px solid var(--clay-deep);
    padding: 0.65rem 0.75rem;
    background: rgba(181, 144, 111, 0.12);
    color: var(--muted);
    font-size: 0.75rem;
    line-height: 1.4;
  }

  label,
  .inline-fields span,
  .single-field span {
    color: var(--muted);
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  input,
  select {
    width: 100%;
    min-height: 44px;
    border: 1px solid var(--line-strong);
    border-radius: 0;
    background: rgba(255, 253, 247, 0.72);
    color: var(--ink);
    font: inherit;
    font-size: 1rem;
    letter-spacing: 0;
    padding: 0.65rem 0.75rem;
  }

  input:focus-visible,
  select:focus-visible {
    outline: 3px solid var(--clay);
    outline-offset: 3px;
  }

  .select-row,
  .inline-fields {
    display: grid;
    gap: 0.75rem;
    min-width: 0;
  }

  .favorite-button {
    align-self: end;
    padding-inline: 0.9rem;
  }

  .chip-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8rem, 1fr));
    gap: 0.5rem;
  }

  .chip-grid button {
    padding-inline: 0.7rem;
  }

  .control-group,
  .draw-mode-panel {
    display: grid;
    gap: 0.75rem;
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }

  .component-list {
    display: grid;
    border-top: 1px solid var(--line);
  }

  .component-list div {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 1rem;
    border-bottom: 1px solid var(--line);
    padding-block: 0.75rem;
  }

  .component-list span {
    color: var(--muted);
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.3;
  }

  .component-list strong {
    flex: 0 0 auto;
    font-size: 0.82rem;
    letter-spacing: 0;
  }

  .results-panel {
    position: sticky;
    top: 1rem;
    display: grid;
    gap: 1rem;
    align-self: start;
  }

  .result-state {
    border-left: 4px solid var(--sage-deep);
    padding: 0.65rem 0.8rem;
    background: rgba(227, 229, 220, 0.7);
    color: var(--ink);
    font-size: 0.84rem;
    font-weight: 800;
    line-height: 1.35;
  }

  .result-state[data-status="guardrailed"] {
    border-color: var(--clay-deep);
  }

  .result-state[data-status="invalid"] {
    border-color: var(--clay);
  }

  .syringe-visual {
    display: grid;
    gap: 0.45rem;
  }

  .syringe-scale {
    position: relative;
    overflow: hidden;
    height: 2.6rem;
    border: 1px solid var(--ink);
    background:
      repeating-linear-gradient(
        90deg,
        transparent 0,
        transparent calc(10% - 1px),
        rgba(32, 37, 34, 0.22) calc(10% - 1px),
        rgba(32, 37, 34, 0.22) 10%
      ),
      rgba(255, 253, 247, 0.78);
  }

  .syringe-fill {
    width: 0%;
    height: 100%;
    background: linear-gradient(90deg, var(--sage), var(--clay));
    transition: width 160ms ease;
  }

  .syringe-ticks {
    display: flex;
    justify-content: space-between;
    color: var(--muted);
    font-size: 0.64rem;
    font-weight: 800;
    letter-spacing: 0.02em;
  }

  .result-grid {
    display: grid;
    gap: 0.6rem;
  }

  .metric {
    display: grid;
    gap: 0.25rem;
    border-top: 1px solid var(--line);
    padding-top: 0.75rem;
  }

  .metric span {
    color: var(--muted);
    font-size: 0.64rem;
    font-weight: 900;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }

  .metric strong {
    font-family: var(--serif);
    font-size: 1.55rem;
    font-weight: 400;
