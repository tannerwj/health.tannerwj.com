---
import { render, type CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"follow">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const profiles = entry.data.profiles ?? [{
  handle: entry.data.handle,
  url: entry.data.url,
  platform: entry.data.platform
}];
---

<article class="follow-entry" id={entry.data.slug}>
  <div class="identity">
    <div class="handles">
      {profiles.map((profile) => (
        <a
          class="handle"
          href={profile.url}
          target="_blank"
          rel="noreferrer"
          aria-label={`Open ${entry.data.name}'s ${profile.handle} profile on ${profile.platform}`}
        >
          {profile.handle}<span aria-hidden="true">↗</span>
        </a>
      ))}
    </div>
    <h3>{entry.data.name}</h3>
    <p class="platform">{Array.from(new Set(profiles.map((profile) => profile.platform))).join(" / ")}</p>
  </div>
  <div class="reason">
    <p>{entry.data.summary}</p>
    <div class="entry-body"><Content /></div>
    {entry.data.practiceOnly && entry.data.practiceNote ? <p class="practice-note">{entry.data.practiceNote}</p> : null}
  </div>
</article>

<style>
  .follow-entry { display: grid; gap: .8rem; margin-top: .85rem; border: 1px solid var(--line); border-top: 3px solid var(--sage); padding: 1rem; background: rgba(248, 246, 238, .42); scroll-margin-top: 1rem; }
  h3 { margin: .38rem 0 0; color: var(--muted); font-family: var(--sans); font-size: .78rem; font-weight: 800; letter-spacing: .03em; line-height: 1.2; }
  .handles { display: grid; justify-items: start; gap: .25rem; }
  .identity .handle { display: inline-flex; gap: .35rem; min-height: 44px; align-items: center; overflow-wrap: anywhere; margin: 0; color: var(--ink); font-family: var(--serif); font-size: clamp(1.45rem, 5vw, 2.35rem); font-weight: 400; letter-spacing: -.015em; line-height: .95; text-decoration: none; text-transform: none; }
  .identity .platform { margin: .4rem 0 0; color: var(--clay-deep); font-size: .59rem; font-weight: 900; letter-spacing: .13em; text-transform: uppercase; }
  .reason > p { max-width: 38rem; margin: 0; color: var(--muted); font-size: .9rem; line-height: 1.45; }
  .entry-body { max-width: 38rem; color: var(--muted); font-size: .82rem; line-height: 1.45; }
  .entry-body :global(p) { margin: .75rem 0 0; }
  a:hover, a:focus-visible { color: var(--clay-deep); }
  .practice-note { margin: .85rem 0 0; border-left: 3px solid var(--clay); padding-left: .65rem; color: var(--clay-deep); font-size: .74rem; font-weight: 800; line-height: 1.4; }
  @media (min-width: 48rem) { .follow-entry { grid-template-columns: minmax(14rem, .8fr) minmax(0, 1.5fr); align-items: start; gap: 2rem; padding: 1.35rem 1.45rem; } }
</style>
