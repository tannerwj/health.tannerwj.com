---
import { render, type CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"protocols">;
  featured?: boolean;
}

const { entry, featured = false } = Astro.props;
const { Content } = await render(entry);
const details = [
  ["Cadence", entry.data.cadence],
  ["Provider", entry.data.provider],
  ["Service", entry.data.service],
  ["Location", entry.data.location]
] as const;
---

<article class:list={["protocol-entry", { "protocol-entry--featured": featured }]}>
  <header>
    <p class="kind">{entry.data.kind}</p>
    <div class="title-row">
      <h3>{entry.data.name}</h3>
      {entry.data.status ? <span class="status">{entry.data.status}</span> : null}
    </div>
    <p class="summary">{entry.data.summary}</p>
  </header>

  {details.some(([, value]) => value) ? (
    <dl class="details">
      {details.map(([label, value]) => value ? <div><dt>{label}</dt><dd>{value}</dd></div> : null)}
    </dl>
  ) : null}

  {entry.data.markers?.length ? (
    <section class="markers" aria-label={`${entry.data.name} markers`}>
      <p>Markers in view</p>
      <ul>{entry.data.markers.map((marker) => <li>{marker}</li>)}</ul>
    </section>
  ) : null}

  <div class="entry-body"><Content /></div>

  {entry.data.sources?.length ? (
    <details class="sources">
      <summary>Sources and context</summary>
      <ul>
        {entry.data.sources.map((source) => (
          <li>
            {source.url ? <a href={source.url} target="_blank" rel="noreferrer">{source.type}</a> : source.type}
            {source.note ? ` — ${source.note}` : null}
          </li>
        ))}
      </ul>
    </details>
  ) : null}

  {entry.data.practiceOnly && entry.data.practiceNote ? <p class="practice-note">{entry.data.practiceNote}</p> : null}
</article>

<style>
  .protocol-entry { border-top: 1px solid var(--line-strong); padding: 1.25rem 0 1.5rem; }
  .protocol-entry--featured { border-top-color: var(--ink); }
  .kind, .status, .markers > p { margin: 0; color: var(--clay-deep); font-size: .65rem; font-weight: 900; letter-spacing: .12em; text-transform: uppercase; }
  .title-row { display: flex; align-items: baseline; justify-content: space-between; gap: 1rem; margin-top: .5rem; }
  h3 { margin: 0; font-family: var(--serif); font-size: clamp(1.9rem, 5vw, 3.3rem); font-weight: 400; letter-spacing: 0; line-height: .9; }
  .status { color: var(--sage-deep); white-space: nowrap; }
  .summary { max-width: 43rem; margin: .8rem 0 0; color: var(--muted); font-size: .97rem; line-height: 1.45; }
  .details { display: grid; grid-template-columns: repeat(2, minmax(0, 1fr)); gap: .75rem 1rem; max-width: 45rem; margin: 1.2rem 0 0; }
  .details div { border-top: 1px solid var(--line); padding-top: .45rem; }
  dt { color: var(--muted); font-size: .62rem; font-weight: 900; letter-spacing: .1em; text-transform: uppercase; }
  dd { margin: .2rem 0 0; font-size: .82rem; font-weight: 800; line-height: 1.3; }
  .markers { margin-top: 1.2rem; }
  .markers ul { display: flex; flex-wrap: wrap; gap: .45rem; margin: .55rem 0 0; padding: 0; list-style: none; }
  .markers li { border: 1px solid var(--sage); padding: .38rem .5rem; font-size: .72rem; font-weight: 800; }
  .entry-body { max-width: 43rem; color: var(--muted); font-size: .9rem; line-height: 1.5; }
  .entry-body :global(p) { margin: 1.1rem 0 0; }
  .sources { max-width: 43rem; margin-top: 1rem; color: var(--muted); font-size: .78rem; line-height: 1.45; }
  summary { cursor: pointer; min-height: 44px; padding-top: .8rem; color: var(--ink); font-weight: 800; }
  .sources ul { margin: 0; padding-left: 1.1rem; }
  .sources a { color: var(--sage-deep); font-weight: 800; }
  .practice-note { max-width: 43rem; margin: 1rem 0 0; border-left: 3px solid var(--clay); padding-left: .65rem; color: var(--clay-deep); font-size: .75rem; font-weight: 800; line-height: 1.4; }
  @media (min-width: 48rem) { .details { grid-template-columns: repeat(4, minmax(0, 1fr)); } }
</style>
